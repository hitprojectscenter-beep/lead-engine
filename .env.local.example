# ─────────────────────────────────────────────────────────────
#  lead-engine — environment variables
#  Copy to .env.local and fill in. The app RUNS WITHOUT any of these
#  (falls back to a local JSON store + heuristic parsing), so you can
#  develop immediately and wire real services in one at a time.
# ─────────────────────────────────────────────────────────────

# Postgres / Neon. If empty → app uses the local JSON dev store (./.data).
# Use the DIRECT (non-pooler) Neon host for `npm run db:push`.
DATABASE_URL=

# OpenAI — used for (1) Whisper transcription of WhatsApp voice notes
# and (2) extracting structured lead fields from free text.
# If empty → transcription is skipped and a heuristic parser is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio WhatsApp (inbound webhook + outbound auto-reply).
# If empty → the webhook still ingests, it just won't send auto-replies,
# and inbound signature validation is skipped (dev only).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Public base URL (used to build QR / landing links). No trailing slash.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Shared secret protecting internal endpoints (cron, etc.). Optional.
APP_SECRET=
